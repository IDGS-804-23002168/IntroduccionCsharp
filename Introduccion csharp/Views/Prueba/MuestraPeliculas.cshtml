@model List<Introduccion_csharp.Models.Pelicula>

@{
    ViewBag.Title = "MuestraPeliculas";
}

<h2>MuestraPeliculas</h2>

<div class="container">
        <div class="row">

        <table>
            <thead>
                <tr>
                    <th>TITULO</th>
                    <th>DURACION</th>
                    <th>PAIS</th>
                    <th>LANZAMIENTO</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var pelicula in Model)
                {
                    <tr>
                        <th>@pelicula.Titulo</th>
                        <th>@pelicula.Duracion</th>
                        <th>@pelicula.Pais</th>
                        <th>@pelicula.Publicacion</th>
                    </tr>
                }

            </tbody>
        </table>
        </div>
    </div>


